# For a local Postgres instance:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/expenses_organizer
#
# For Supabase: use the "Connection Pooling" string (Transaction mode, port 6543)
# from Project Settings -> Database, e.g.:
# postgresql+psycopg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
# The direct connection host (db.<project-ref>.supabase.co) only resolves over IPv6,
# which many networks can't reach - the pooler works over IPv4 and avoids that failure.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/expenses_organizer
APP_NAME=Expenses Organizer
APP_ENV=development
UPLOAD_DIR=uploads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# OCR (Tesseract, local, sin costo). Instalar con:
#   winget install --id UB-Mannheim.TesseractOCR -e
#   winget install --id oschwartz10612.Poppler -e
# Si tesseract/poppler quedan en el PATH, deja estas 3 variables vacias.
# Si no, apunta a las rutas absolutas de tu instalacion.
OCR_LANGUAGES=spa+eng
TESSERACT_CMD=
POPPLER_PATH=
TESSDATA_PREFIX=

# Extraccion estructurada con Claude (corre siempre, despues de cada OCR).
# Crea tu API key en https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Origenes permitidos para CORS (el frontend de Vite corre en :5173 por defecto).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
